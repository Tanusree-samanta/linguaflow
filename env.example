# ─────────────────────────────────────────────────────────
# LinguaFlow — Environment Variables
# ─────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your key below
# 3. Never commit .env to version control
# ─────────────────────────────────────────────────────────


# ── Google Cloud Translation API ──────────────────────────
# Required for translation. Get yours at:
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_API_KEY=your_google_api_key_here


# ── Flask Backend ─────────────────────────────────────────
# Optional: override the default host/port for the Flask server
# FLASK_RUN_HOST=0.0.0.0
# FLASK_RUN_PORT=5000
# FLASK_DEBUG=false


# ── Streamlit Frontend ────────────────────────────────────
# Optional: override the Flask backend URL that frontend.py points to
# BACKEND_URL=http://localhost:5000
